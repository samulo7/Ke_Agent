APP_ENV=dev
APP_PORT=8000
APP_DEBUG=false

DINGTALK_CLIENT_ID=replace-me
DINGTALK_CLIENT_SECRET=replace-me
DINGTALK_AGENT_ID=replace-me
DINGTALK_STREAM_ENDPOINT=https://api.dingtalk.com/v1.0/gateway/connections/open

QWEN_API_KEY=replace-me
QWEN_CHAT_MODEL=qwen-plus
QWEN_INTENT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4

PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=keagent
PG_USER=keagent
PG_PASSWORD=replace-me
PGVECTOR_TABLE_DOCS=knowledge_docs
PGVECTOR_TABLE_CHUNKS=doc_chunks
PGVECTOR_TOP_K=5

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_MASK_SECRETS=true
RESPONSE_TONE_DEFAULT=conversational
RESPONSE_TONE_BY_INTENT=

DEV_BYPASS_AUTH=false
LOCAL_FAKE_DINGTALK_USER=
USE_MOCK_QWEN=false
